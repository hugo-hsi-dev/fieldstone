{
	"name": "fieldstone",
	"version": "0.0.1",
	"description": "monorepo for fieldstone",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm --dir test/minimal dev",
		"build": "pnpm --dir test/minimal build",
		"db:push": "pnpm -r --filter './test/*' --if-present db:push",
		"test": "pnpm -r --filter './packages/*' test && pnpm test:e2e",
		"test:e2e": "pnpm --dir test/minimal test:e2e",
		"lint": "eslint . && pnpm -r --filter './packages/*' --if-present lint",
		"format": "pnpm -r --filter './packages/*' --if-present format"
	},
	"devDependencies": {
		"eslint": "^10.4.1"
	}
}
