// Project tasks configuration. See https://zed.dev/docs/tasks for documentation.
//
// Example:
[
  {
    "label": "install deps",
    "command": "pnpm",
    "args": ["install", "--frozen-lockfile"],
    "hooks": ["create_worktree"],
    "reveal": "no_focus",
    "hide": "on_success",
  },
  {
    "label": "push db",
    "command": "pnpm",
    "args": ["db:push"],
    "hooks": ["create_worktree"],
    "reveal": "no_focus",
    "hide": "on_success",
  },
]
