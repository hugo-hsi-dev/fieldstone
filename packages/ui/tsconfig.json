{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "esnext",
    "types": ["@sveltejs/kit"]
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}
