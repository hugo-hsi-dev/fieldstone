{
	"name": "@hugo-hsi-dev/ui",
	"version": "0.2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hugo-hsi-dev/fieldstone.git",
		"directory": "packages/ui"
	},
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./admin.css": "./dist/admin.css"
	},
	"sideEffects": [
		"*.css"
	],
	"scripts": {
		"build": "svelte-package -i src -o dist",
		"test": "vitest --run",
		"typecheck": "svelte-check --tsconfig ./tsconfig.json",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"check:publish": "publint"
	},
	"dependencies": {
		"@hugo-hsi-dev/remotes": "workspace:*",
		"@hugo-hsi-dev/routes": "workspace:*",
		"@hugo-hsi-dev/schema": "workspace:*",
		"@lucide/svelte": "^1.21.0",
		"@tiptap/core": "^3.27.1",
		"@tiptap/pm": "^3.27.1",
		"@tiptap/starter-kit": "^3.27.1",
		"bits-ui": "^2.18.1",
		"mode-watcher": "^1.1.0"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.64.0",
		"svelte": "^5.56.1"
	},
	"devDependencies": {
		"@hugo-hsi-dev/eslint-config": "workspace:*",
		"@hugo-hsi-dev/prettier-config": "workspace:*",
		"@hugo-hsi-dev/tsconfig": "workspace:*",
		"@sveltejs/kit": "^2.64.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"eslint": "^10.4.1",
		"prettier": "^3.8.3",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	}
}
