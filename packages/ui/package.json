{
	"name": "@fieldstone/ui",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"svelte": "./src/index.ts",
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./admin.css": {
			"default": "./src/admin.css"
		}
	},
	"sideEffects": [
		"*.css"
	],
	"scripts": {
		"test": "vitest --run",
		"typecheck": "svelte-check",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"dependencies": {
		"@fieldstone/remotes": "workspace:*",
		"@fieldstone/routes": "workspace:*",
		"@fieldstone/schema": "workspace:*",
		"bits-ui": "^2.18.1"
	},
	"peerDependencies": {
		"svelte": "^5.56.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vitest": "^4.1.8"
	}
}
