{
	"name": "@hugo-hsi-dev/ui",
	"version": "0.2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hugo-hsi-dev/fieldstone.git",
		"directory": "packages/ui"
	},
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./admin.css": "./dist/admin.css"
	},
	"sideEffects": [
		"*.css"
	],
	"scripts": {
		"build": "svelte-package -i src -o dist",
		"test": "vitest --run",
		"typecheck": "svelte-check --tsconfig ./tsconfig.json",
		"lint": "prettier --check . && eslint .",
		"lint:format": "prettier --check .",
		"format": "prettier --write .",
		"check:publish": "publint"
	},
	"dependencies": {
		"@hugo-hsi-dev/admin-runtime": "workspace:*",
		"@hugo-hsi-dev/schema": "workspace:*",
		"@lucide/svelte": "^1.22.0"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.68.0",
		"svelte": "^5.56.4"
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"eslint": "^10.6.0",
		"prettier": "^3.9.3",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	}
}
