{
	"name": "@fieldstone/ui",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"svelte": "./src/index.ts",
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./admin.css": {
			"default": "./src/admin.css"
		}
	},
	"sideEffects": [
		"*.css"
	],
	"scripts": {
		"test": "vitest --run",
		"typecheck": "svelte-check --tsconfig ./tsconfig.json",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"dependencies": {
		"@fieldstone/remotes": "workspace:*",
		"@fieldstone/routes": "workspace:*",
		"@fieldstone/schema": "workspace:*",
		"@lucide/svelte": "^1.21.0",
		"@tiptap/core": "^3.27.1",
		"@tiptap/pm": "^3.27.1",
		"@tiptap/starter-kit": "^3.27.1",
		"bits-ui": "^2.18.1",
		"mode-watcher": "^1.1.0"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.64.0",
		"svelte": "^5.56.1"
	},
	"devDependencies": {
		"@fieldstone/eslint-config": "workspace:*",
		"@fieldstone/prettier-config": "workspace:*",
		"@fieldstone/tsconfig": "workspace:*",
		"@sveltejs/kit": "^2.64.0",
		"eslint": "^10.4.1",
		"prettier": "^3.8.3",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	}
}
