{
  "name": "@hugo-hsi-dev/compiler",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hugo-hsi-dev/fieldstone.git",
    "directory": "packages/compiler"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-ts-package.mjs",
    "check:publish": "publint && attw --pack . --profile esm-only",
    "test": "vitest --run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hugo-hsi-dev/schema": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
