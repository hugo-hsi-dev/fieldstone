{
  "name": "@fieldstone/codegen",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest --run --passWithNoTests",
    "typecheck": "files=$(find src -name '*.ts' -print 2>/dev/null); [ -z \"$files\" ] || printf '%s\\n' \"$files\" | xargs tsgo --noEmit --allowImportingTsExtensions --moduleResolution bundler --module esnext --target esnext --strict --skipLibCheck --types node",
    "lint": "oxlint .",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@fieldstone/compiler": "workspace:*",
    "@fieldstone/schema": "workspace:*",
    "@libsql/client": "^0.15.15",
    "drizzle-orm": "^0.45.2"
  },
  "peerDependencies": {
    "drizzle-kit": "^0.31.10"
  },
  "devDependencies": {
    "@types/node": "^24.13.1",
    "@typescript/native-preview": "7.0.0-dev.20260611.2",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.17.0",
    "oxlint": "^1.29.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
