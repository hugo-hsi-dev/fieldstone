{
  "name": "@hugo-hsi-dev/remotes",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hugo-hsi-dev/fieldstone.git",
    "directory": "packages/remotes"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest --run --passWithNoTests",
    "check:publish": "publint && attw --pack . --profile esm-only",
    "typecheck": "tsgo -p tsconfig.json",
    "lint": "oxlint .",
    "format": "oxfmt -c ../../config/oxfmt/oxfmt.json ."
  },
  "dependencies": {
    "@hugo-hsi-dev/admin-runtime": "workspace:*",
    "@hugo-hsi-dev/compiler": "workspace:*",
    "@hugo-hsi-dev/routes": "workspace:*",
    "@hugo-hsi-dev/schema": "workspace:*",
    "valibot": "^1.4.1"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.64.0",
    "svelte": "^5.56.1"
  },
  "devDependencies": {
    "@hugo-hsi-dev/oxfmt-config": "workspace:*",
    "@hugo-hsi-dev/oxlint-config": "workspace:*",
    "@hugo-hsi-dev/tsconfig": "workspace:*",
    "@sveltejs/kit": "^2.64.0",
    "@types/node": "^24.13.1",
    "@typescript/native-preview": "7.0.0-dev.20260611.2",
    "oxfmt": "^0.17.0",
    "oxlint": "^1.29.0",
    "vitest": "^4.1.8"
  }
}
