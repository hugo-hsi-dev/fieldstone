{
  "name": "@fieldstone/remotes",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest --run --passWithNoTests",
    "typecheck": "files=$(find src -name '*.ts' -print 2>/dev/null); [ -z \"$files\" ] || printf '%s\\n' \"$files\" | xargs tsgo --noEmit --allowImportingTsExtensions --moduleResolution bundler --module esnext --target esnext --strict --skipLibCheck --types node",
    "lint": "oxlint .",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@fieldstone/admin-runtime": "workspace:*",
    "@fieldstone/compiler": "workspace:*",
    "@fieldstone/routes": "workspace:*",
    "@fieldstone/schema": "workspace:*",
    "valibot": "^1.4.1"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.63.0",
    "svelte": "^5.56.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.1",
    "@typescript/native-preview": "7.0.0-dev.20260611.2",
    "oxfmt": "^0.17.0",
    "oxlint": "^1.29.0",
    "vitest": "^4.1.8"
  }
}
