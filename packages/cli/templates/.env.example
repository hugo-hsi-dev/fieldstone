# Copy to `.env` and adjust. The dev server reads these via `$env/dynamic/private`.
# Every value below has a working dev default, so `pnpm dev` runs with no .env at all
# — but a real deployment MUST set BETTER_AUTH_SECRET (see the warning below).

# --- Fieldstone CMS database -------------------------------------------------
# SQLite file for your CMS collections/globals. The Fieldstone CLI (`generate` /
# `push`) reads this; the Vite plugin's `db.url` in vite.config.ts points at the
# same file by default. The two are NOT kept in sync automatically — if you change
# DATABASE_URL, update `db.url` in vite.config.ts to match, or the CLI and the
# running app will read different databases.
# Use a path (./local.db) or a libsql URL (file:local.db).
DATABASE_URL=local.db

# --- Auth (Better Auth) ------------------------------------------------------
# Signing secret for sessions. There is an INSECURE hard-coded dev fallback in
# src/lib/auth.ts so first-run setup is zero-config — DO NOT ship without setting
# a real, random secret here (e.g. `openssl rand -hex 32`). Leaving it unset in
# production means anyone can forge a session.
BETTER_AUTH_SECRET=

# Optional. Pins the auth base URL. Leave empty in dev and Better Auth infers it
# from the request, so it works on any port (5173, 4173, ...). Set it in prod,
# e.g. https://example.com
BETTER_AUTH_URL=

# Optional. Better Auth keeps its user/session tables in a SEPARATE SQLite file
# so Fieldstone's schema push (which only manages collection/global tables) never
# touches them. Defaults to file:auth.db when unset.
AUTH_DATABASE_URL=
