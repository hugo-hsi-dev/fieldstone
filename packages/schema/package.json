{
  "name": "@hugo-hsi-dev/schema",
  "version": "0.3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hugo-hsi-dev/fieldstone.git",
    "directory": "packages/schema"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-ts-package.mjs",
    "check:publish": "publint && attw --pack . --profile esm-only",
    "test": "vitest --run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
