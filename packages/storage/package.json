{
  "name": "@hugo-hsi-dev/storage",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hugo-hsi-dev/fieldstone.git",
    "directory": "packages/storage"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/rewrite-dts-extensions.mjs dist",
    "check:publish": "publint && attw --pack . --profile esm-only",
    "test": "vitest --run",
    "typecheck": "tsgo -p tsconfig.json",
    "lint": "oxlint .",
    "format": "oxfmt -c ../../config/oxfmt/oxfmt.json ."
  },
  "dependencies": {
    "@hugo-hsi-dev/schema": "workspace:*"
  },
  "devDependencies": {
    "@hugo-hsi-dev/oxfmt-config": "workspace:*",
    "@hugo-hsi-dev/oxlint-config": "workspace:*",
    "@hugo-hsi-dev/tsconfig": "workspace:*",
    "@types/node": "^24.13.1",
    "@typescript/native-preview": "7.0.0-dev.20260611.2",
    "oxfmt": "^0.17.0",
    "oxlint": "^1.29.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
