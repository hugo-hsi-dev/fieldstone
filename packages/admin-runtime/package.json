{
  "name": "@hugo-hsi-dev/admin-runtime",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hugo-hsi-dev/fieldstone.git",
    "directory": "packages/admin-runtime"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./sveltekit": {
      "types": "./dist/sveltekit.d.ts",
      "default": "./dist/sveltekit.js"
    },
    "./admin-paths": {
      "types": "./dist/admin-paths.d.ts",
      "default": "./dist/admin-paths.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-ts-package.mjs",
    "check:publish": "publint && attw --pack . --profile esm-only",
    "test": "vitest --run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hugo-hsi-dev/runtime": "workspace:*",
    "@hugo-hsi-dev/schema": "workspace:*"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.64.0",
    "sharp": ">=0.33.0"
  },
  "peerDependenciesMeta": {
    "@sveltejs/kit": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@libsql/client": "^0.15.15",
    "@sveltejs/kit": "^2.64.0",
    "@types/node": "^26.0.1",
    "sharp": "^0.35.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
