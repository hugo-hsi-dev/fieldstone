{
  "name": "@fieldstone/admin-runtime",
  "version": "0.0.1",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/rewrite-dts-extensions.mjs dist",
    "check:publish": "publint && attw --pack . --profile esm-only",
    "test": "vitest --run",
    "typecheck": "tsgo -p tsconfig.json",
    "lint": "oxlint .",
    "format": "oxfmt -c ../../config/oxfmt/oxfmt.json ."
  },
  "dependencies": {
    "@fieldstone/runtime": "workspace:*",
    "@fieldstone/schema": "workspace:*",
    "@fieldstone/storage": "workspace:*"
  },
  "peerDependencies": {
    "sharp": ">=0.33.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@fieldstone/oxfmt-config": "workspace:*",
    "@fieldstone/oxlint-config": "workspace:*",
    "@fieldstone/tsconfig": "workspace:*",
    "@libsql/client": "^0.15.15",
    "@types/node": "^24.13.1",
    "@typescript/native-preview": "7.0.0-dev.20260611.2",
    "oxfmt": "^0.17.0",
    "oxlint": "^1.29.0",
    "sharp": "^0.35.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
